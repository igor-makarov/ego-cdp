#!/usr/bin/env node

import fs from 'fs';
import path from 'path';
import { parseArgs } from 'util';
import * as chrome from '../lib/launch/chrome.js';
import * as wsDaemon from '../lib/launch/ws-daemon.js';
import { isRunning } from '../lib/common/pid.js';
import { getWsDaemonSocketPath } from '../lib/common/config.js';
import { runWsCommand } from '../lib/cdp/ws.js';

async function start({ headless = false } = {}) {
  const chromePid = chrome.getPid();
  const daemonPid = wsDaemon.getPid();
  const chromeAlive = chromePid && isRunning(chromePid);
  const daemonAlive = daemonPid && isRunning(daemonPid);

  if (chromeAlive && daemonAlive) {
    console.log(`Already running (chrome ${chromePid}, daemon ${daemonPid}).`);
    return;
  }

  if (chromeAlive !== daemonAlive) {
    console.log('Partial state detected, restarting...');
    stop();
  }

  const cdpInfo = await chrome.start({ headless });
  if (cdpInfo) {
    await wsDaemon.start(cdpInfo);
  }
}

function stop() {
  wsDaemon.stop();
  chrome.stop();
}

async function status() {
  const chromePid = chrome.getPid();

  if (!chromePid) {
    console.log('Chrome: no pid');
  } else {
    try {
      const response = await runWsCommand({
        message: '{"id":1,"method":"Browser.getVersion"}',
        timeout: 5000,
      });
      const info = JSON.parse(response);
      const product = info.result?.product ?? 'unknown';
      console.log(`Chrome: pid ${chromePid} — ${product}`);
    } catch {
      console.log(`Chrome: pid ${chromePid} — CDP not responding`);
    }
  }

  const daemonPid = wsDaemon.getPid();
  if (!daemonPid) {
    console.log('WS daemon: no pid');
  } else if (isRunning(daemonPid)) {
    console.log(`WS daemon: pid ${daemonPid}, socket ${getWsDaemonSocketPath()}`);
  } else {
    console.log(`WS daemon: pid ${daemonPid} (not running)`);
  }
}

async function ws() {
  const { values, positionals } = parseArgs({
    args: process.argv.slice(3),
    options: {
      timeout: { type: 'string', default: '60000' },
      output: { type: 'string' },
    },
    allowPositionals: true,
  });

  const message = positionals[0];
  if (!message) {
    console.error('Usage: ego-cdp ws <message> [--timeout=ms] [--output=FILE]');
    process.exit(1);
  }

  const result = await runWsCommand({
    message,
    timeout: parseInt(values.timeout, 10),
  });

  if (values.output) {
    fs.writeFileSync(values.output, result);
    console.log(`Written to ${values.output}`);
  } else {
    process.stdout.write(result);
  }
}

const command = process.argv[2];
switch (command) {
  case 'start': {
    const { values } = parseArgs({
      args: process.argv.slice(3),
      options: {
        headless: { type: 'boolean', default: false },
      },
      allowPositionals: false,
    });
    start({ headless: values.headless });
    break;
  }
  case 'stop':   stop();   break;
  case 'status': status(); break;
  case 'ws':     ws();     break;
  default:
    console.error(`Usage: ${path.basename(process.argv[1])} {start|stop|status|ws}`);
    process.exit(1);
}
